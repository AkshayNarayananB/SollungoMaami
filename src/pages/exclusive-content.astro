---
import MainLayout from "../layouts/MainLayout.astro";
import AuthGatekeeper from "../components/AuthGatekeeper.jsx";
---

<MainLayout title="Exclusive Content">
  <AuthGatekeeper client:load />

  <div class="max-w-4xl mx-auto py-12 px-4">
    <div class="bg-gradient-to-r from-amber-500 to-orange-600 rounded-3xl p-8 text-white mb-10 shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-4xl font-bold mb-2">Welcome, Member! 🧡</h1>
          <p class="opacity-90">Enjoy your exclusive spices and stories.</p>
        </div>
        <button 
          onclick="import { auth } from '../lib/firebase'; auth.signOut().then(() => window.location.href = '/')"
          class="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-lg text-sm transition-all"
        >
          Logout
        </button>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      </div>
  </div>
</MainLayout>
