---
import MainLayout from "../layouts/MainLayout.astro";
import AuthGatekeeper from "../components/AuthGatekeeper.jsx";
import LibraryDropdowns from "../components/LibraryDropdowns.jsx"; // We'll create this
---

<MainLayout title="Member Library">
  <AuthGatekeeper client:load />

  <div class="max-w-4xl mx-auto py-12 px-4">
    <div class="bg-gradient-to-r from-amber-500 to-orange-600 rounded-3xl p-8 text-white mb-10 shadow-lg">
       <div class="flex items-center justify-between">
        <div>
          <h1 class="text-4xl font-bold mb-2">Member Library 🧡</h1>
          <p class="opacity-90">Secure access to your exclusive PDF resources.</p>
        </div>
        <button id="logout-btn" class="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-lg text-sm transition-all">Logout</button>
      </div>
    </div>

    <LibraryDropdowns client:only="react" />
  </div>
</MainLayout>

<script>
  import { auth } from '../lib/firebase';
  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    await auth.signOut();
    window.location.href = '/login';
  });
</script>
