---
import MainLayout from "../layouts/MainLayout.astro";
import AuthGatekeeper from "../components/AuthGatekeeper.jsx";
import LibraryDropdowns from "../components/LibraryDropdowns.jsx";
import Comments from "../components/Comments.jsx";
---

<MainLayout title="Member Library">
  {/* The Gatekeeper checks if the user is logged in via Firebase */}
  <AuthGatekeeper client:load />

  <div class="max-w-4xl mx-auto py-12 px-4">
    {/* Header Section */}
    <div class="bg-gradient-to-r from-amber-500 to-orange-600 rounded-3xl p-8 text-white mb-10 shadow-lg">
       <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <h1 class="text-4xl font-bold mb-2">Member Library 🧡</h1>
          <p class="opacity-90 italic">Exclusive recipes and guides for our inner circle.</p>
        </div>
        
        {/* Logout Button */}
        <button 
          id="logout-btn" 
          class="bg-white/20 hover:bg-white/40 active:scale-95 px-6 py-2.5 rounded-xl text-sm font-bold transition-all backdrop-blur-md border border-white/30"
        >
          Logout
        </button>
      </div>
    </div>

    {/* PDF Resources Section */}
    <LibraryDropdowns client:only="react" />

    {/* Custom Comments Section */}
    <Comments client:only="react" /> 
  </div>
</MainLayout>

<script>
  import { auth } from '../lib/firebase';

  const logoutBtn = document.getElementById('logout-btn');

  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      // Visual feedback: disable button while processing
      const originalText = logoutBtn.textContent;
      logoutBtn.textContent = "Logging out...";
      logoutBtn.style.opacity = "0.7";
      logoutBtn.style.pointerEvents = "none";

      try {
        // Sign out from Firebase
        await auth.signOut();
        
        // Clear any specific session data if needed
        console.log("User signed out successfully.");

        // Redirect back to login page
        window.location.href = '/login'; 
      } catch (error) {
        console.error("Error during logout:", error);
        alert("Oops! Something went wrong while logging out.");
        
        // Reset button state
        logoutBtn.textContent = originalText;
        logoutBtn.style.opacity = "1";
        logoutBtn.style.pointerEvents = "all";
      }
    });
  }
</script>

<style>
  /* Optional: Smooth entry animation for the library */
  .max-w-4xl {
    animation: fadeIn 0.8s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
