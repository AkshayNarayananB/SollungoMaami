---
import MainLayout from "../../layouts/MainLayout.astro";
import AuthGatekeeper from "../../components/AuthGatekeeper.jsx";
import { getProtectedUrl } from "../../lib/r2";

const { searchParams } = Astro.url;
const fileName = searchParams.get('file');

if (!fileName) return Astro.redirect('/exclusive-content');

// 1. Generate a fresh, 60-second link on the server
let signedUrl = "";
try {
  signedUrl = await getProtectedUrl(fileName);
} catch (e) {
  return Astro.redirect('/404');
}

// 2. Add PDF restrictions to the URL
const protectedPdfUrl = `${signedUrl}#toolbar=0&navpanes=0`;
---

<MainLayout title={`Viewing: ${fileName}`}>
  <AuthGatekeeper client:load />

  <div class="max-w-5xl mx-auto py-8 px-4 h-screen flex flex-col">
    <div class="flex items-center justify-between mb-4">
      <a href="/exclusive-content" class="text-amber-600 font-bold hover:underline">
        ← Back to Library
      </a>
      <span class="text-xs bg-amber-100 text-amber-800 px-2 py-1 rounded">Member Only</span>
    </div>

    <div class="flex-grow bg-white rounded-2xl overflow-hidden shadow-2xl relative border border-gray-200" oncontextmenu="return false;">
      <iframe 
        src={protectedPdfUrl} 
        width="100%" 
        height="100%" 
        style="border: none;"
      ></iframe>
      
      <div class="absolute top-0 right-0 w-24 h-16 pointer-events-none bg-transparent"></div>
    </div>
  </div>
</MainLayout>
