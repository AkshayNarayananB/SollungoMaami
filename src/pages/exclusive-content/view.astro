---
import MainLayout from "../../layouts/MainLayout.astro";
import AuthGatekeeper from "../../components/AuthGatekeeper.jsx";
import PdfViewer from "../../components/PdfViewer.jsx";

// No server-side fetching here! 
// This keeps your frontend 100% static.
---

<MainLayout title="Member View">
  <AuthGatekeeper client:load />

  <div class="max-w-5xl mx-auto py-8 px-4 h-screen flex flex-col">
    <div class="flex items-center justify-between mb-4">
      <a href="/exclusive-content" class="text-amber-600 font-bold">← Back to Library</a>
    </div>

    <div class="flex-grow bg-white rounded-2xl overflow-hidden shadow-2xl relative border border-gray-200">
      <PdfViewer client:only="react" fileName={new URLSearchParams(window.location.search).get('file')} />
      <div class="absolute top-0 right-0 w-24 h-16 pointer-events-none bg-transparent"></div>
    </div>
  </div>
</MainLayout>

<script>
  // Small fix to make the URL search params available to the React component
  import { PdfViewer } from '../../components/PdfViewer.jsx';
</script>
